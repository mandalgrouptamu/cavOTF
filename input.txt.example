[general]
# Folder containing one subfolder per geometry/trajectory seed
geometry_path = /scratch/user/u.sw216206/project1/water/
# File names inside each geometry folder
init_xyz_file = thermaliz_water__InTheBox.dat
init_vel_file = thermaliz_water_vel__InTheBox.dat
trajectory_prefix = trajectory_
# Optional: override the built-in clean template bundle
# clean_template_dir = /path/to/custom/DFTB_clean
# Thermostat controls (applied only to run-0 when enabled)
use_thermostat = false
thermostat_type = andersen
thermostat_steps = 25
thermostat_BetaScale = 0.75
collision_frequency = 0.001
thermostat_reassign_particles = 99

[physics]
# Number of trajectories/clients
nk = 81
beta = 1052.8
# Optional: override beta for run-0 only
beta_run0 = 1052.8
lambda = 0.001
omega_c = 0.19/27.2114
eta_b = 0.0001 * 2
# Photon and dipole controls
use_thermostat = false
thermostat_type = andersen
thermostat_steps = 25
thermostat_BetaScale = 0.75
thermostat_reassign_particles = 99
calculate_dipole_derivatives = true
# Write dipole derivatives every N steps
dipole_derivative_interval = 2
# Number of initial thermalization steps for cavity coordinates
thermal_steps = 150000
# laser------------------------
omega_l = 0.190/27.2114
gl_val = 0.05          # in eV 
# number of low boxes to couple
gl_n_active = 6 
# laser to matter ------------------------
omega_lm = 0.190/27.2114
gl_valm = 0.0          # in eV 
# number of low boxes to couple
gl_n_activem = 6  
# laser to matter time 
toff_lm = 1000000 * 41.3413733365614


[outputs]
# Control which artifacts are written during dynamics and server updates
write_logfile = true
write_results = true
# Track k-space coordinates (qk, pk) from the server and optionally echo them
record_k_space = true
print_k_space = false
# Client-side outputs
write_xyz_trajectory = true
write_histogram = true
write_output_client = true
write_midpoint_snapshots = true

[dftb]
# Override any keyword passed to the ASE Dftb calculator (leave unset to use defaults)
# Use "off" or "none" to remove a line entirely.
Hamiltonian_SCCTolerance = 1e-5
Hamiltonian_MaxSCCIterations = 400
Hamiltonian_Mixer = Anderson { MixingParameter = 0.026 }
Hamiltonian_ConvergentSccOnly = Yes
Hamiltonian_MaxAngularMomentum_O = p
Hamiltonian_MaxAngularMomentum_H = s
Hamiltonian_Charge = 0.0
Hamiltonian_ReadInitialCharges = Yes
Hamiltonian_SpinConstants = {O = { -0.035 -0.030 -0.030 -0.028 } H = { -0.072 }}
Options_WriteDetailedXml = No
Options_WriteEigenvectors = No
Options_WriteResultsTag = Yes
kpts = (3, 3, 3)

[hpc]
cpus_per_job = 1
partition = compute
account = myaccount
run_get_mu = true
run_dynamics = true
# Path to SK set used by DFTB+
dftb_prefix = /scratch/user/u.sw216206/dftb_sk_files/mio-1-1
# Command used to launch DFTB+
dftb_command = /scratch/user/u.sw216206/.conda/envs/dftb/bin/dftb+ > PREFIX.out
# Optional custom sbatch template
sbatch_template = sbatch_template.sh.example
# Walltime limit for generated sbatch scripts
walltime = 2-00:00:00
# Memory request for sbatch scripts
memory = 126G
